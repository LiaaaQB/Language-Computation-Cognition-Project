    "# Plot the strongest correlation results\n",
    "plot_corr = corr_table.copy()\n",
    "plot_corr[\"abs_spearman\"] = plot_corr[\"spearman_r\"].abs()\n",
    "plot_corr = plot_corr.sort_values(\"abs_spearman\", ascending=False).head(10)\n",
    "\n",
    "plot_corr[\"label\"] = (\n",
    "    plot_corr[\"eye_feature\"].astype(str) + \" -> \" + plot_corr[\"outcome\"].astype(str)\n",
    ")\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(11, 6))\n",
    "bar_colors = [\"#4C78A8\", \"#F58518\", \"#54A24B\", \"#EECA3B\", \"#B279A2\", \"#FF9DA7\", \"#9D755D\", \"#72B7B2\"]\n",
    "bar_positions = ax.barh(plot_corr[\"label\"], plot_corr[\"abs_spearman\"], color=bar_colors[:len(plot_corr)])\n",
    "ax.invert_yaxis()\n",
    "ax.set_xlabel(\"Absolute Spearman correlation\")\n",
    "ax.set_title(\"Top absolute Spearman correlations\")\n",
    "ax.grid(axis=\"x\", linestyle=\"--\", alpha=0.35)\n",
    "\n",
    "for bar, val in zip(bar_positions, plot_corr[\"abs_spearman\"]):\n",
    "    ax.text(val + 0.01, bar.get_y() + bar.get_height() / 2, f\"{val:.3f}\", va=\"center\", ha=\"left\")\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
