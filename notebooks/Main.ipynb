   "source": [
    "# Experiment 5.1: Evaluation regimes\n",
    "\n",
    "\n",
    "regime_features = feature_groups[\"Top 3 Features\"]\n",
    "\n",
    "regime_df = (\n",
    "    df[regime_features + [\"acc\", \"subj\", \"book\"]]\n",
    "    .dropna()\n",
    "    .reset_index(drop=True)\n",
    "    .copy()\n",
    ")\n",
    "regime_df[\"acc\"] = regime_df[\"acc\"].astype(int)\n",
    "\n",
    "\n",
    "def make_classifier():\n",
    "    \"\"\"Return the same model configuration used in Experiment 4.\"\"\"\n",
    "    return make_pipeline(\n",
    "        StandardScaler(),\n",
    "        LogisticRegression(\n",
    "            max_iter=1000,\n",
    "            class_weight=\"balanced\",\n",
    "            random_state=42,\n",
    "        ),\n",
    "    )\n",
    "\n",
    "\n",
    "def evaluate_split(train_idx, test_idx):\n",
    "    \"\"\"Train and evaluate one valid train/test split.\"\"\"\n",
    "    train = regime_df.iloc[train_idx]\n",
    "    test = regime_df.iloc[test_idx]\n",
    "\n",
    "    y_train = train[\"acc\"]\n",
    "    y_test = test[\"acc\"]\n",
    "\n",
    "    # These metrics require both classes in training and testing\n",
    "    if (\n",
    "        len(train) < 5\n",
    "        or len(test) < 2\n",
    "        or y_train.nunique() < 2\n",
    "        or y_test.nunique() < 2\n",
    "    ):\n",
    "        return None\n",
    "\n",
    "    model = make_classifier()\n",
    "    model.fit(train[regime_features], y_train)\n",
    "\n",
    "    predictions = model.predict(test[regime_features])\n",
    "    probabilities = model.predict_proba(test[regime_features])[:, 1]\n",
    "\n",
    "    return {\n",
    "        \"balanced_accuracy\": balanced_accuracy_score(y_test, predictions),\n",
    "        \"f1_macro\": f1_score(y_test, predictions, average=\"macro\"),\n",
    "        \"roc_auc\": roc_auc_score(y_test, probabilities),\n",
    "        \"n_test\": len(test),\n",
    "        \"y_true\": y_test.to_numpy(),\n",
    "        \"y_score\": probabilities,\n",
    "    }\n",
    "\n",
    "\n",
    "def collect_group_splits(group_column):\n",
    "    \"\"\"Evaluate leave-one-group-out splits.\"\"\"\n",
    "    results = []\n",
    "\n",
    "    for held_out_group in sorted(regime_df[group_column].unique()):\n",
    "        test_idx = np.flatnonzero(\n",
    "            regime_df[group_column].to_numpy() == held_out_group\n",
    "        )\n",
    "        train_idx = np.flatnonzero(\n",
    "            regime_df[group_column].to_numpy() != held_out_group\n",
    "        )\n",
    "\n",
    "        result = evaluate_split(train_idx, test_idx)\n",
    "        if result is not None:\n",
    "            results.append(result)\n",
    "\n",
    "    return results\n",
    "\n",
    "\n",
    "# 1. Seen reader / seen passage: ordinary stratified CV\n",
    "seen_seen_results = []\n",
    "\n",
    "regime_cv = StratifiedKFold(\n",
    "    n_splits=5,\n",
    "    shuffle=True,\n",
    "    random_state=42,\n",
    ")\n",
    "\n",
    "for train_idx, test_idx in regime_cv.split(\n",
    "    regime_df[regime_features],\n",
    "    regime_df[\"acc\"],\n",
    "):\n",
    "    result = evaluate_split(train_idx, test_idx)\n",
    "    if result is not None:\n",
    "        seen_seen_results.append(result)\n",
    "\n",
    "\n",
    "# 2. Seen reader / unseen passage\n",
    "unseen_passage_results = collect_group_splits(\"book\")\n",
    "\n",
    "# 3. Unseen reader / seen passage\n",
    "unseen_reader_results = collect_group_splits(\"subj\")\n",
    "\n",
    "\n",
    "# 4. Unseen reader-and-passage evaluation\n",
    "\n",
    "blocked_results = []\n",
    "\n",
    "for reader in sorted(regime_df[\"subj\"].unique()):\n",
    "    for passage in sorted(regime_df[\"book\"].unique()):\n",
    "        test_mask = (\n",
    "            regime_df[\"subj\"].eq(reader)\n",
    "            | regime_df[\"book\"].eq(passage)\n",
    "        ).to_numpy()\n",
    "\n",
    "        result = evaluate_split(\n",
    "            np.flatnonzero(~test_mask),\n",
    "            np.flatnonzero(test_mask),\n",
    "        )\n",
    "\n",
    "        if result is not None:\n",
    "            blocked_results.append(result)\n",
    "\n",
    "\n",
    "regime_results = {\n",
    "    \"Seen reader / seen passage\": seen_seen_results,\n",
    "    \"Seen reader / unseen passage\": unseen_passage_results,\n",
    "    \"Unseen reader / seen passage\": unseen_reader_results,\n",
    "    \"Blocked reader and passage\": blocked_results,\n",
    "}\n",
    "\n",
    "\n",
    "# Summarize the results\n",
    "metric_columns = [\"balanced_accuracy\", \"f1_macro\", \"roc_auc\"]\n",
    "\n",
    "summary = pd.DataFrame(\n",
    "    [\n",
    "        {\n",
    "            \"regime\": regime,\n",
    "            \"valid_splits\": len(results),\n",
    "            **{\n",
    "                metric: (\n",
    "                    np.mean([result[metric] for result in results])\n",
    "                    if results else np.nan\n",
    "                )\n",
    "                for metric in metric_columns\n",
    "            },\n",
    "        }\n",
    "        for regime, results in regime_results.items()\n",
    "    ]\n",
    ")\n",
    "\n",
    "print(\"Evaluation regimes\")\n",
    "display(summary.round(3))\n",
    "\n",
    "\n",
    "# Plot ROC curves\n",
    "fig, ax = plt.subplots(figsize=(8, 6))\n",
    "\n",
    "for regime, results in regime_results.items():\n",
    "    if not results:\n",
    "        continue\n",
    "\n",
    "    y_true = np.concatenate([result[\"y_true\"] for result in results])\n",
    "    y_score = np.concatenate([result[\"y_score\"] for result in results])\n",
    "\n",
    "    fpr, tpr, _ = roc_curve(y_true, y_score)\n",
    "    pooled_auc = roc_auc_score(y_true, y_score)\n",
    "\n",
    "    ax.plot(\n",
    "        fpr,\n",
    "        tpr,\n",
    "        linewidth=2,\n",
    "        label=f\"{regime} (AUC = {pooled_auc:.2f})\",\n",
    "    )\n",
    "\n",
    "ax.plot(\n",
    "    [0, 1],\n",
    "    [0, 1],\n",
    "    color=\"gray\",\n",
    "    linestyle=\"--\",\n",
    "    linewidth=1,\n",
    ")\n",
    "\n",
    "ax.set(\n",
    "    title=\"ROC Curves Across Evaluation Regimes\",\n",
    "    xlabel=\"False Positive Rate\",\n",
    "    ylabel=\"True Positive Rate\",\n",
    "    xlim=(0, 1),\n",
    "    ylim=(0, 1.05),\n",
    ")\n",
    "ax.legend(loc=\"lower right\")\n",
    "ax.grid(alpha=0.25)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
