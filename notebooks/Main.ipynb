   ],
   "source": [
    "# Define distinct feature blocks for the ablation study, including our optimized tier\n",
    "feature_groups = {\n",
    "    \"Eye-Tracking Only\": [\n",
    "        \"regression_rate\",\n",
    "        \"fixation_count\",\n",
    "        \"mean_fix_duration\",\n",
    "        \"sd_fix_duration\",\n",
    "        \"total_reading_time\",\n",
    "        \"mean_pupil_size\",\n",
    "        \"mean_saccade_amplitude\",\n",
    "    ],\n",
    "    \"Subjective Only\": [\n",
    "    \"difficulty\",\n",
    "    \"confidence\",\n",
    "    \"sleepiness\",\n",
    "    \"sleephours\",\n",
    "    \"familiarity\",\n",
    "    \"recognition\",\n",
    "    \"interest\",\n",
    "    \"pressured\",\n",
    "],\n",
    "\n",
    "    \"Top 2 Features\": [\n",
    "    \"confidence\",\n",
    "    \"mean_fix_duration\",\n",
    "],\n",
    "    \"Top 3 Features\": [\n",
    "    \"confidence\",\n",
    "    \"mean_fix_duration\",\n",
    "    \"fixation_count\",\n",
    "],\n",
    "    \"Top 4 Features\": [\n",
    "        \"confidence\",\n",
    "        \"mean_fix_duration\",\n",
    "        \"total_reading_time\",\n",
    "        \"fixation_count\",\n",
    "    ],\n",
    "\n",
    "    \"Combined (Full)\": [\n",
    "    \"regression_rate\",\n",
    "    \"fixation_count\",\n",
    "    \"mean_fix_duration\",\n",
    "    \"sd_fix_duration\",\n",
    "    \"total_reading_time\",\n",
    "    \"mean_pupil_size\",\n",
    "    \"mean_saccade_amplitude\",\n",
    "\n",
    "    \"difficulty\",\n",
    "    \"confidence\",\n",
    "    \"sleepiness\",\n",
    "    \"sleephours\",\n",
    "    \"familiarity\",\n",
    "    \"recognition\",\n",
    "    \"interest\",\n",
    "    \"pressured\",\n",
    "],\n",
    "    \"Top Subjective Features\": [\n",
    "    \"confidence\",\n",
    "    \"familiarity\",\n",
    "]\n",
    "}\n",
    "\n",
    "# drop rows with missing values in the selected features and target variable\n",
    "all_needed_features = feature_groups[\"Combined (Full)\"]\n",
    "model_df = df[all_needed_features + [\"acc\"]].dropna().copy()\n",
    "\n",
    "X_full = model_df[all_needed_features]\n",
    "y = (model_df[\"acc\"] >= 0.6).astype(int)\n",
    "\n",
    "print(f\"\\nRows used for predictive modeling: {len(model_df)}\")\n",
    "majority_class_ratio = max(y.mean(), 1 - y.mean())\n",
    "print(f\"Majority Class Baseline Accuracy: {majority_class_ratio:.3f}\")\n",
    "\n",
    "# Setup cross-validation\n",
    "cv = StratifiedKFold(n_splits=5, shuffle=True, random_state=42)\n",
    "\n",
    "# Define evaluation metrics that account for class imbalance\n",
    "scorers = {\n",
    "    \"Balanced Acc\": \"balanced_accuracy\",\n",
    "    \"F1 Macro\": \"f1_macro\",\n",
    "    \"ROC-AUC\": \"roc_auc\"\n",
    "}\n",
    "\n",
    "print(\"\\n=== Ablation Study: Model Comparison ===\")\n",
    "print(f\"{'Feature Group':<25} | {'Balanced Acc':<12} | {'F1 Macro':<12} | {'ROC-AUC':<12}\")\n",
    "print(\"-\" * 72)\n",
    "\n",
    "ablation_results = {}\n",
    "# ablation study loop\n",
    "for group_name, features in feature_groups.items():\n",
    "    X_subset = model_df[features]\n",
    "\n",
    "    model_pipeline = make_pipeline(\n",
    "        StandardScaler(),\n",
    "        LogisticRegression(max_iter=1000, class_weight='balanced', random_state=42)\n",
    "    )\n",
    "\n",
    "    # cv\n",
    "    group_scores = {}\n",
    "    for metric_name, scorer_key in scorers.items():\n",
    "        scores = cross_val_score(model_pipeline, X_subset, y, cv=cv, scoring=scorer_key)\n",
    "        group_scores[metric_name] = scores.mean()\n",
    "\n",
    "    print(f\"{group_name:<25} | {group_scores['Balanced Acc']:.3f}        | {group_scores['F1 Macro']:.3f}        | {group_scores['ROC-AUC']:.3f}\")\n",
    "    ablation_results[group_name] = group_scores\n",
    "\n",
    "\n",
    "\n",
    "# Interpreting Feature Coefficients (Full Model)\n",
    "final_pipeline = make_pipeline(\n",
    "    StandardScaler(),\n",
    "    LogisticRegression(max_iter=1000, class_weight='balanced', random_state=42)\n",
    ")\n",
    "final_pipeline.fit(X_full, y)\n",
    "\n",
    "log_reg = final_pipeline.named_steps[\"logisticregression\"]\n",
    "coef_table = pd.DataFrame({\n",
    "    \"feature\": all_needed_features,\n",
    "    \"coefficient\": log_reg.coef_[0]\n",
    "})\n",
    "\n",
    "# Calculate magnitude for clean absolute sorting\n",
    "coef_table[\"abs_coefficient\"] = coef_table[\"coefficient\"].abs()\n",
    "coef_table = coef_table.sort_values(\"abs_coefficient\", ascending=False)\n",
    "\n",
    "print(\"\\nBalanced Logistic Regression Feature Weights\")\n",
    "print(coef_table.drop(columns=\"abs_coefficient\").round(4).to_string(index=False))"
   ]
  },
  {
