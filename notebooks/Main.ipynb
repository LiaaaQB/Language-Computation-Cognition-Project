    "## Accuracy prediction model"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 16,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/"
    },
    "id": "MuATKmUhQ5-s",
    "outputId": "94973737-4290-4943-cdf7-589e5049aa94"
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "\n",
      "Rows used for prediction model: 368\n",
      "Accuracy baseline: 0.611\n",
      "\n",
      "=== Logistic regression prediction ===\n",
      "Mean CV accuracy: 0.631\n",
      "Accuracy std: 0.030\n",
      "Mean CV ROC-AUC: 0.624\n",
      "ROC-AUC std: 0.041\n"
     ]
    }
   ],
   "source": [
    "\n",
    "model_features = [\n",
    "    \"regression_rate\",\n",
    "    \"fixation_count\",\n",
    "    \"mean_fix_duration\",\n",
    "    \"sd_fix_duration\",\n",
    "    \"total_reading_time\",\n",
    "    \"mean_pupil_size\",\n",
    "    \"mean_saccade_amplitude\",\n",
    "\n",
    "    \"difficulty\",\n",
    "    \"confidence\",\n",
    "    \"sleepiness\",\n",
    "    \"sleephours\",\n",
    "\n",
    "    \"familiarity\",\n",
    "    \"recognition\",\n",
    "    \"interest\",\n",
    "    \"pressured\",\n",
    "]\n",
    "\n",
    "model_df = df[model_features + [\"acc\"]].dropna()\n",
    "\n",
    "X = model_df[model_features]\n",
    "y = (model_df[\"acc\"] >= 0.6).astype(int)\n",
    "\n",
    "print(f\"\\nRows used for prediction model: {len(model_df)}\")\n",
    "print(f\"Accuracy baseline: {max(y.mean(), 1 - y.mean()):.3f}\")\n",
    "\n",
    "model = make_pipeline(\n",
    "    StandardScaler(),\n",
    "    LogisticRegression(max_iter=1000)\n",
    ")\n",
    "\n",
    "cv = StratifiedKFold(n_splits=5, shuffle=True, random_state=42)\n",
    "\n",
    "accuracy_scores = cross_val_score(\n",
    "    model, X, y, cv=cv, scoring=\"accuracy\"\n",
    ")\n",
    "\n",
    "auc_scores = cross_val_score(\n",
    "    model, X, y, cv=cv, scoring=\"roc_auc\"\n",
    ")\n",
    "\n",
    "print(\"\\n=== Logistic regression prediction ===\")\n",
    "print(f\"Mean CV accuracy: {accuracy_scores.mean():.3f}\")\n",
    "print(f\"Accuracy std: {accuracy_scores.std():.3f}\")\n",
    "print(f\"Mean CV ROC-AUC: {auc_scores.mean():.3f}\")\n",
    "print(f\"ROC-AUC std: {auc_scores.std():.3f}\")"
   ]
  },
