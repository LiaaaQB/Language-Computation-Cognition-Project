    "id": "4p8qjqM4kJwV"
   },
   "source": [
    "## Experiment 5.2: Analysis of Misclassified Samples"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/",
     "height": 1000
    },
    "id": "UatjLo-PbRf8",
    "outputId": "b7adfccb-861b-48b5-f51e-d846a6e88e0f"
   },
   "outputs": [],
   "source": [
    "# Experiment 5.2: Analysis of Misclassified Samples\n",
    "analysis_features = feature_groups[\"Top 3 Features\"]\n",
    "\n",
    "analysis_df = (\n",
    "    df[\n",
    "        analysis_features +\n",
    "        [\"acc\", \"subj\", \"book\"]\n",
    "    ]\n",
    "    .dropna()\n",
    "    .reset_index(drop=True)\n",
    "    .copy()\n",
    ")\n",
    "\n",
    "analysis_df["acc"] = (analysis_df["acc"] >= 0.6).astype(int)\n",
    "\n",
    "X = analysis_df[analysis_features]\n",
    "y = analysis_df[\"acc\"]\n",
    "\n",
    "\n",
    "# Collect one out-of-fold prediction per sample\n",
    "\n",
    "cv = StratifiedKFold(\n",
    "    n_splits=5,\n",
    "    shuffle=True,\n",
    "    random_state=42,\n",
    ")\n",
    "\n",
    "predictions = np.zeros(len(analysis_df), dtype=int)\n",
    "probabilities = np.zeros(len(analysis_df))\n",
    "\n",
    "for train_idx, test_idx in cv.split(X, y):\n",
    "\n",
    "    pipeline = make_pipeline(\n",
    "        StandardScaler(),\n",
    "        LogisticRegression(\n",
    "            max_iter=1000,\n",
    "            class_weight=\"balanced\",\n",
    "            random_state=42,\n",
    "        )\n",
    "    )\n",
    "\n",
    "    pipeline.fit(X.iloc[train_idx], y.iloc[train_idx])\n",
    "\n",
    "    predictions[test_idx] = pipeline.predict(X.iloc[test_idx])\n",
    "\n",
    "    probabilities[test_idx] = (\n",
    "        pipeline\n",
    "        .predict_proba(X.iloc[test_idx])[:, 1]\n",
    "    )\n",
    "\n",
    "errors_df = analysis_df.copy()\n",
    "\n",
    "errors_df[\"prediction\"] = predictions\n",
    "errors_df[\"probability\"] = probabilities\n",
    "errors_df[\"correct\"] = (\n",
    "    errors_df[\"prediction\"] == errors_df[\"acc\"]\n",
    ")\n",
    "\n",
    "# Prediction type\n",
    "errors_df[\"Prediction Type\"] = \"Unknown\"\n",
    "\n",
    "errors_df.loc[\n",
    "    (errors_df.acc == 1) & (errors_df.prediction == 1),\n",
    "    \"Prediction Type\"\n",
    "] = \"True Positive\"\n",
    "\n",
    "errors_df.loc[\n",
    "    (errors_df.acc == 0) & (errors_df.prediction == 0),\n",
    "    \"Prediction Type\"\n",
    "] = \"True Negative\"\n",
    "\n",
    "errors_df.loc[\n",
    "    (errors_df.acc == 0) & (errors_df.prediction == 1),\n",
    "    \"Prediction Type\"\n",
    "] = \"False Positive\"\n",
    "\n",
    "errors_df.loc[\n",
    "    (errors_df.acc == 1) & (errors_df.prediction == 0),\n",
    "    \"Prediction Type\"\n",
    "] = \"False Negative\"\n",
    "\n",
    "# Confusion Matrix\n",
    "cm = confusion_matrix(y, predictions)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(5,5))\n",
    "\n",
    "im = ax.imshow(cm, cmap=\"Blues\")\n",
    "\n",
    "for i in range(cm.shape[0]):\n",
    "    for j in range(cm.shape[1]):\n",
    "        ax.text(\n",
    "            j,\n",
    "            i,\n",
    "            cm[i, j],\n",
    "            ha=\"center\",\n",
    "            va=\"center\",\n",
    "            fontsize=12,\n",
    "        )\n",
    "\n",
    "ax.set_xticks([0,1])\n",
    "ax.set_yticks([0,1])\n",
    "\n",
    "ax.set_xticklabels([\"Negative\",\"Positive\"])\n",
    "ax.set_yticklabels([\"Negative\",\"Positive\"])\n",
    "\n",
    "ax.set_xlabel(\"Predicted\")\n",
    "ax.set_ylabel(\"True\")\n",
    "ax.set_title(\"Confusion Matrix\")\n",
    "\n",
    "plt.colorbar(im)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# Prediction type counts\n",
    "print(\"\\nPrediction counts\")\n",
    "print(errors_df[\"Prediction Type\"].value_counts())\n",
    "\n",
    "# Passage-level error rates\n",
    "passage_errors = (\n",
    "    errors_df\n",
    "    .groupby(\"book\")\n",
    "    .agg(\n",
    "        Error_Rate=(\"correct\", lambda x: 1 - x.mean()),\n",
    "        Samples=(\"correct\",\"size\"),\n",
    "    )\n",
    "    .sort_values(\"Error_Rate\", ascending=False)\n",
    ")\n",
    "\n",
    "print(\"\\nPassage error rates\")\n",
    "display(passage_errors)\n",
    "\n",
    "plt.figure(figsize=(8,5))\n",
    "\n",
    "passage_errors[\"Error_Rate\"].plot(\n",
    "    kind=\"bar\",\n",
    "    color=\"darkorange\"\n",
    ")\n",
