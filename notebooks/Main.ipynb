   "source": [
    "x_features = [\n",
    "    \"regression_rate\",\n",
    "    \"regression_count\",\n",
    "    \"fixation_count\",\n",
    "    \"mean_fix_duration\",\n",
    "    \"sd_fix_duration\",\n",
    "    \"total_reading_time\",\n",
    "    \"mean_pupil_size\",\n",
    "    \"mean_saccade_amplitude\",\n",
    "]\n",
    "\n",
    "y_variables = [\n",
    "    \"difficulty\",\n",
    "    \"confidence\",\n",
    "    \"sleepiness\",\n",
    "    \"sleephours\",\n",
    "    \"familiarity\",\n",
    "    \"recognition\",\n",
    "    \"interest\",\n",
    "    \"pressured\",\n",
    "    \"acc\",\n",
    "]\n",
    "\n",
    "results = []\n",
    "\n",
    "for x in x_features:\n",
    "    for y in y_variables:\n",
    "        temp = df[[x, y]].dropna()\n",
    "\n",
    "        if len(temp) < 3:\n",
    "            continue\n",
    "\n",
    "        pearson_r, pearson_p = pearsonr(temp[x], temp[y])\n",
    "        spearman_r, spearman_p = spearmanr(temp[x], temp[y])\n",
    "\n",
    "        results.append({\n",
    "            \"eye_feature\": x,\n",
    "            \"outcome\": y,\n",
    "            \"n\": len(temp),\n",
    "            \"pearson_r\": pearson_r,\n",
    "            \"pearson_p\": pearson_p,\n",
    "            \"spearman_r\": spearman_r,\n",
    "            \"spearman_p\": spearman_p,\n",
    "        })\n",
    "\n",
    "corr_table = pd.DataFrame(results)\n",
    "\n",
    "# Sort by strongest Spearman association\n",
    "corr_table[\"abs_spearman\"] = corr_table[\"spearman_r\"].abs()\n",
    "corr_table = corr_table.sort_values(\"abs_spearman\", ascending=False)\n",
    "\n",
    "print(\"\\n=== Correlation results ===\")\n",
    "print(corr_table.drop(columns=\"abs_spearman\").round(4).to_string(index=False))"
   ]
