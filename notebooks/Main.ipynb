  {
   "cell_type": "markdown",
   "metadata": {
    "id": "SFxQs6GtQCik"
   },
   "source": [
    "## Imports and loading the data files"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "B6tDpNSEgjhp"
   },
   "outputs": [],
   "source": [
    "\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "from pathlib import Path\n",
    "from scipy.stats import pearsonr, spearmanr\n",
    "from sklearn.model_selection import cross_val_score, StratifiedKFold\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "from sklearn.pipeline import make_pipeline\n",
    "from sklearn.linear_model import LogisticRegression\n",
    "from sklearn.metrics import make_scorer, roc_auc_score\n",
    "import matplotlib.pyplot as plt\n",
    "from sklearn.model_selection import cross_val_score\n",
    "from sklearn.pipeline import make_pipeline\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "from sklearn.linear_model import LogisticRegression\n",
    "from sklearn.metrics import balanced_accuracy_score, f1_score\n",
    "from sklearn.metrics import (\n",
    "    balanced_accuracy_score,\n",
    "    f1_score,\n",
    "    roc_auc_score,\n",
    "    roc_curve,\n",
    ")\n",
    "from sklearn.metrics import confusion_matrix"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "noEPKSh1fCzK"
   },
   "outputs": [],
   "source": [
    "# edit path to data here if neccessary\n",
    "\n",
    "LABELS_PATH = Path(\"Data/18sat_labels.csv\")\n",
    "FIX_PATH = Path(\"Data/18sat_fixfinal.csv\")\n",
    "\n",
    "labels = pd.read_csv(LABELS_PATH)\n",
    "fix = pd.read_csv(FIX_PATH)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 13,
   "metadata": {
    "id": "Xg-hZvvVQOYc"
   },
   "outputs": [],
   "source": [
    "# Keeping only reading fixations\n",
    "fix = fix[fix[\"type\"].astype(str).str.lower().str.strip() == \"reading\"].copy()\n",
    "\n",
    "# Standardize subject/book names\n",
    "fix[\"subj\"] = fix[\"Session_Name_\"].fillna(fix[\"RECORDING_SESSION_LABEL\"]).astype(str).str.strip()\n",
    "fix[\"book\"] = fix[\"book_name\"].fillna(fix[\"book\"]).astype(str).str.strip()\n",
    "\n",
    "labels[\"subj\"] = labels[\"subj\"].astype(str).str.strip()\n",
    "labels[\"book\"] = labels[\"book\"].astype(str).str.strip()\n",
    "\n",
    "# Mark regressions: leftward saccades\n",
    "fix[\"is_regression\"] = (\n",
    "    fix[\"PREVIOUS_SAC_DIRECTION\"].astype(str).str.upper().str.strip() == \"LEFT\"\n",
    ").astype(int)\n",
    "\n",
    "# Numeric columns\n",
    "for col in [\"CURRENT_FIX_DURATION\", \"CURRENT_FIX_PUPIL\", \"PREVIOUS_SAC_AMPLITUDE\"]:\n",
    "    fix[col] = pd.to_numeric(fix[col], errors=\"coerce\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "id": "eqYPxdx3QhCH"
   },
   "source": [
    "## Build and organize the features from the data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/"
    },
    "id": "z-gMNdcFQf2R",
    "outputId": "ca8e452e-b5a5-476f-b196-11de99fd2928"
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Matched subject-book pairs: 368\n"
     ]
    }
   ],
   "source": [
    "# Aggregate eye-tracking features per subject-book\n",
    "eye_features = fix.groupby([\"subj\", \"book\"]).agg(\n",
    "    fixation_count=(\"CURRENT_FIX_DURATION\", \"count\"),\n",
    "    regression_count=(\"is_regression\", \"sum\"),\n",
    "    mean_fix_duration=(\"CURRENT_FIX_DURATION\", \"mean\"),\n",
    "    sd_fix_duration=(\"CURRENT_FIX_DURATION\", \"std\"),\n",
    "    total_reading_time=(\"CURRENT_FIX_DURATION\", \"sum\"),\n",
    "    mean_pupil_size=(\"CURRENT_FIX_PUPIL\", \"mean\"),\n",
    "    mean_saccade_amplitude=(\"PREVIOUS_SAC_AMPLITUDE\", \"mean\"),\n",
    ").reset_index()\n",
    "\n",
    "# Normalize regression count\n",
    "eye_features[\"regression_rate\"] = (\n",
    "    eye_features[\"regression_count\"] / eye_features[\"fixation_count\"]\n",
    ")\n",
    "\n",
    "# Merge with labels\n",
    "df = labels.merge(eye_features, on=[\"subj\", \"book\"], how=\"inner\")\n",
    "\n",
    "label_cols = [\n",
    "    \"acc\", \"confidence\", \"difficulty\", \"familiarity\", \"recognition\",\n",
    "    \"interest\", \"pressured\", \"sleepiness\", \"sleephours\"\n",
    "]\n",
    "\n",
    "for col in label_cols:\n",
    "    if col in df.columns:\n",
    "        df[col] = pd.to_numeric(df[col], errors=\"coerce\")\n",
    "\n",
    "print(f\"Matched subject-book pairs: {len(df)}\")\n"
   ]
  },
